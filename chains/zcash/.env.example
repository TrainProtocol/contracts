# Zcash Configuration

# Mnemonic phrase 
MNEMONIC=your twelve word mnemonic phrase goes here for testing purposes only

# Private key (hex format)
PRIVATE_KEY=your_private_key_hex

# Transparent address for balance checking (optional)
TRANSPARENT_ADDRESS=

# Testnet RPC URL
# Public testnet endpoints
TESTNET_RPC_URL=https://testnet.zcash-rpc.com


# Mainnet RPC URL
# Public mainnet endpoints 
MAINNET_RPC_URL=https://zcash-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Network (testnet or mainnet)
NETWORK=testnet

